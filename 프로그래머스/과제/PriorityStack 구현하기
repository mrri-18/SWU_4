class PriorityStack:
    stack=[]
    prior=[]

    def __init__(self):
        pass

    def push(self, data, is_priority=False):
        if is_priority==False: 
            PriorityStack.stack.append(data)
        else:
            PriorityStack.stack.append(data)
            PriorityStack.prior.append(len(PriorityStack.stack)-1)
    def pop(self):
        if len(PriorityStack.stack)==0:
            return None
        if len(PriorityStack.prior)>0 and PriorityStack.prior[-1]+1==len(PriorityStack.stack): #가장 최신 스택이 우선순위인 경우
            PriorityStack.prior.pop()
        return PriorityStack.stack.pop()
    def pop_priority(self):
        if len(PriorityStack.prior)==0:
            return None
        idx=PriorityStack.prior.pop()
        del PriorityStack.stack[idx+1:]
        return PriorityStack.stack.pop()
        

        
